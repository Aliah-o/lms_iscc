# ISCC LMS - Apache Configuration
# Required for proper deployment on shared hosting (InfinityFree, etc.)

# Disable directory listing
Options -Indexes

# Set default charset
AddDefaultCharset UTF-8

# PHP settings (adjust if needed for your host)
<IfModule mod_php.c>
    php_value upload_max_filesize 64M
    php_value post_max_size 64M
    php_value max_execution_time 300
    php_value max_input_time 300
    php_value memory_limit 256M
</IfModule>

# Enable rewrite engine
<IfModule mod_rewrite.c>
    RewriteEngine On

    # Force HTTPS (uncomment if your host supports SSL)
    # RewriteCond %{HTTPS} off
    # RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

    # Block access to sensitive files
    RewriteRule ^config/ - [F,L]
    RewriteRule ^installed\.lock$ - [F,L]
    RewriteRule ^\.git - [F,L]
    RewriteRule ^composer\.(json|lock)$ - [F,L]
    RewriteRule ^\.env$ - [F,L]

    # Default index
    DirectoryIndex index.php
</IfModule>

# Block access to hidden files (except .htaccess)
<FilesMatch "^\.(?!htaccess)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Prevent access to SQL files
<FilesMatch "\.(sql|lock)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order Allow,Deny
        Deny from all
    </IfModule>
</FilesMatch>

# Cache static assets
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType text/css "access plus 1 month"
    ExpiresByType application/javascript "access plus 1 month"
    ExpiresByType image/png "access plus 1 month"
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/gif "access plus 1 month"
    ExpiresByType image/svg+xml "access plus 1 month"
</IfModule>

# Error handling
ErrorDocument 403 "Access Denied"
ErrorDocument 404 "Page Not Found"
